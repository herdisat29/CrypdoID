# ===========================
# FIREBASE CLIENT-SIDE CONFIG
# Set these in Cloud Run -> Edit Revision -> Variables & Secrets
# or in your local .env.local for development
# ===========================
VITE_FIREBASE_API_KEY=your_firebase_web_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_DATABASE_ID=your_firestore_database_id

# ===========================
# SERVER-SIDE SECRETS
# Set these in Cloud Run env vars ONLY — never commit!
# ===========================
GEMINI_API_KEY=your_gemini_api_key_from_aistudio_SEPARATE_from_firebase_key
